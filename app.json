{
  "expo": {
    "name": "Room  Service",
    "slug": "rs",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.RS",
      "infoPlist": {
        "NSCameraUsageDescription": "This app requires access to the camera to take photos for user profile customization.",
        "NSLocationWhenInUseUsageDescription": "This app would like to access your location in order to make the delivery to you"
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.RS",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "scheme": "room-service",

    "extra": {
      "eas": { "projectId": "7df9a269-6549-4677-bda2-3d9cc03c63e2" }
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1",
            "flipper": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#BC6C25"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],

    "platforms": ["ios", "android", "web"]
  }
}
