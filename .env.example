# Copy to .env and fill in your values. Do not commit .env.

# Backend base URL (no trailing slash)
SERVER_URL=http://192.168.1.80:3000

# Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_PUBLISHABLE_KEY=

# Google Maps API key
GOOGLE_MAPS_API_KEY=

# Google OAuth — iOS client from Google Cloud Console
GOOGLE_IOS_CLIENT_ID=

# Google OAuth — Web client from Firebase / Google Cloud (used for native sign-in)
GOOGLE_WEB_CLIENT_ID=

# Derived from iOS client ID: com.googleusercontent.apps.<client-id-prefix>
GOOGLE_IOS_URL_SCHEME=

# Firebase web app config (Firebase Console → Project settings)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
